PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Primary MongoDB connection variable (db.js reads MONGO_URI first)
MONGO_URI=mongodb://127.0.0.1:27017/routewise
# Legacy alias accepted by db.js; keep both in sync if you switch to Atlas
MONGODB_URI=mongodb://127.0.0.1:27017/routewise

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters in production
JWT_SECRET=replace-with-a-strong-secret-at-least-32-chars

# ── LLM providers ─────────────────────────────────────────────────────────────
# At least one is required for RAG extraction, AI summary, and live status
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key
TOGETHER_API_KEY=your-together-api-key

# ── Web search (Serper) ───────────────────────────────────────────────────────
# Required for live train search, PNR lookup, and seat availability RAG
SERPER_API_KEY=your-serper-api-key

# ── Embeddings ────────────────────────────────────────────────────────────────
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Maps / Geocoding ──────────────────────────────────────────────────────────
# Optional — used by the geocode fallback. Leave blank to use OSM-only mode.
GOOGLE_MAPS_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Leave blank in development — all origins are allowed when this is unset.
CORS_ORIGIN=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Leave blank in development — the Vite proxy forwards /api/* to localhost:4000.
# Set to your production backend URL when building for production.
VITE_API_BASE_URL=

# ── Scheduler intervals (milliseconds) ───────────────────────────────────────
# Default: 24 hours each
TRAIN_REINGEST_INTERVAL_MS=86400000
TRAIN_ALERT_CHECK_INTERVAL_MS=86400000
